# === required ===
ANTHROPIC_API_KEY=sk-ant-xxx
TELEGRAM_BOT_TOKEN=123456:ABC-DEF

# === Defaults ===
# AIBOY_ASSISTANT_NAME=aiboy
# AIBOY_TIMEZONE=Europe/Berlin
# AIBOY_DATA_DIR=~/.aiboy
# AIBOY_SANDBOX_MODE=docker

# === LLM ===
